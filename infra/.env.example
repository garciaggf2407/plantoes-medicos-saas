# Copiar para infra/.env e preencher os valores reais.
# infra/.env NUNCA deve ser commitado (adicionar ao .gitignore do
# ambiente que o criar, se ainda não estiver coberto).
#
# Restrição importante: POSTGRES_SUPERUSER_PASSWORD e
# PLANTOES_APP_DB_PASSWORD são interpolados dentro de comandos SQL
# via substituição de shell simples (infra/entrypoint-migrate.sh), não
# via mecanismo de escaping do psql — por isso NÃO PODEM CONTER
# APÓSTROFO (').  Use apenas letras, números e símbolos comuns
# (ex.: gerar com `openssl rand -hex 24`).

# --- PostgreSQL ---
# Senha do superusuário "postgres", usada SÓ pelo serviço one-off
# "migrate" (nunca pela aplicação em runtime — ver
# docs/operations/runbooks.md, seção 1, passo 4).
POSTGRES_SUPERUSER_PASSWORD=

# Senha da role de runtime restrita "plantoes_app" (sujeita a RLS).
# Definida automaticamente pelo serviço "migrate" via ALTER ROLE —
# não precisa ser criada manualmente antes do primeiro
# "docker compose up".
PLANTOES_APP_DB_PASSWORD=

# Porta do host mapeada para o Postgres (útil para inspecionar com
# um cliente psql local). Mudar se 5432 já estiver em uso no host.
POSTGRES_HOST_PORT=5432

# --- Sessão ---
# >= 32 caracteres aleatórios. Único por ambiente — nunca reaproveitar
# entre dev/staging/produção (ver runbook de Deploy).
SESSION_SECRET=
SESSION_TTL_SECONDS=3600
# true em qualquer ambiente atrás de HTTPS (produção/staging real).
# false só é aceitável em HTTP puro local (docker compose local sem TLS).
COOKIE_SECURE=true

# --- OIDC ---
# Deixar os três em branco usa o FakeOidcProvider local (nunca rodar
# assim em produção real — ver runbook "Indisponibilidade do
# provedor OIDC").
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3001/auth/callback

# --- Rede / portas expostas no host ---
WEB_ORIGIN=http://localhost:3000
API_HOST_PORT=3001
WEB_HOST_PORT=3000
# Baked no bundle do cliente do Next.js em BUILD time (ver
# infra/web.Dockerfile) — precisa ser a URL que o NAVEGADOR usa para
# falar com a API, não um nome de serviço interno do Docker.
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Notificações / email ---
EMAIL_PROVIDER=console
NOTIFICATIONS_MAX_ATTEMPTS=5
NOTIFICATIONS_BACKOFF_MS=2000
NOTIFICATIONS_POLL_INTERVAL_MS=1000

# --- Observabilidade (opcional) ---
# Sem isso, traces/métricas vão só para o console de cada container
# (ver T-5.2.2). Preencher com um endpoint OTLP HTTP real quando
# houver um backend de observabilidade.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Imagem ---
# Usado pelo runbook de Rollback para apontar para uma tag de imagem
# anterior conhecida-boa sem precisar editar este arquivo/o compose.
PLANTOES_IMAGE_TAG=local
