# DATABASE_URL é usada tanto pela aplicação em runtime quanto pela
# CLI do Prisma (migrate/generate). Para runtime, USE SEMPRE a role
# restrita "plantoes_app" (criada pela migration app_role_grants) —
# ela é a única sujeita às políticas de Row-Level Security. Rodar a
# aplicação com um usuário superusuário (ex.: "postgres") ignora RLS
# silenciosamente. Para comandos `prisma migrate`, use uma conexão
# privilegiada (ex.: role "postgres") apenas naquele comando pontual,
# nunca como valor padrão deste arquivo.
DATABASE_URL="postgresql://plantoes_app:CHANGE_ME@localhost:5432/plantoes_medicos?schema=public"
PORT=3001
WEB_ORIGIN="http://localhost:3000"

# OIDC — deixe OIDC_ISSUER_URL vazio para usar o double local
# (FakeOidcProvider) enquanto não houver credenciais de um provedor
# real (Auth0/Clerk/etc.). Nunca coloque valores reais neste arquivo
# .env.example; use um .env local não versionado.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI="http://localhost:3001/auth/callback"

# Sessão (cookie assinado HMAC) — obrigatório, minimo 16 caracteres.
SESSION_SECRET=
SESSION_TTL_SECONDS=3600
COOKIE_SECURE=true
