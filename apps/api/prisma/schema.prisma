// Schema inicial — BP-2026-07-10-002 (T-1.1.3)
// Toda entidade escopada por hospital carrega organizationId.
// RLS por organizationId é aplicada via migração SQL complementar
// (Prisma não expressa CREATE POLICY nativamente — ver migration.sql).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DOCTOR
  HOSPITAL_ADMIN
  SUPERADMIN
}

enum CredentialStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  FILLED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  COMPLETED
  DEAD_LETTER
}

/// Hospital (tenant). Todas as demais entidades hospitalares
/// referenciam organizationId e ficam sujeitas a RLS por esta linha.
model Organization {
  id        String   @id @default(uuid())
  name      String
  /// Timezone IANA do hospital (ex.: America/Sao_Paulo), usada para
  /// converter os horários UTC armazenados em Shift.
  timezone  String
  /// Perfil do hospital (BP-2026-07-12-001) -- todos opcionais para não
  /// quebrar hospitais provisionados antes deste campo existir.
  city        String?
  address     String?
  description String?  @db.Text
  photoUrl    String?  @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  credentials     Credential[]
  shifts          Shift[]
  applications    Application[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  outboxEvents    OutboxEvent[]
  emailDeliveries EmailDelivery[]

  @@map("organizations")
}

/// Identidade autenticada via OIDC. Nunca armazena senha.
/// organizationId é obrigatório para hospital_admin, nulo para
/// superadmin (escopo global) e nulo para doctor (não pertence a
/// um hospital; credenciamento é por Credential).
model User {
  id             String    @id @default(uuid())
  oidcSubject    String    @unique @map("oidc_subject")
  email          String    @unique
  role           UserRole
  organizationId String?   @map("organization_id")
  /// Opt-out de notificações por email (T-5.1.4). Respeitado antes de
  /// QUALQUER envio — nunca depois. Não afeta notificações in-app.
  emailOptOut    Boolean   @default(false) @map("email_opt_out")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization       Organization?  @relation(fields: [organizationId], references: [id])
  doctorProfile       DoctorProfile?
  createdShifts        Shift[]        @relation("ShiftCreatedBy")
  reviewedCredentials  Credential[]   @relation("CredentialReviewedBy")
  decidedApplications  Application[]  @relation("ApplicationDecidedBy")
  notifications        Notification[]
  auditLogsAsActor     AuditLog[]     @relation("AuditLogActor")
  emailDeliveries      EmailDelivery[]

  @@index([organizationId])
  @@map("users")
}

/// Perfil médico (1:1 com User de role DOCTOR).
model DoctorProfile {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  crmNumber    String   @map("crm_number")
  specialties  String[]
  contactPhone String?  @map("contact_phone")
  /// Cidade de pertencimento do médico (BP-2026-07-13-001) -- opcional,
  /// usada como filtro padrão (trocável) na busca de plantões por cidade.
  /// Validada contra Organization.city já cadastradas, nunca texto livre.
  city         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  credentials  Credential[]
  applications Application[]

  @@map("doctor_profiles")
}

/// Credenciamento de CRM revisado por hospital. Um médico pode ter
/// uma credencial distinta por hospital (revisão independente).
model Credential {
  id              String            @id @default(uuid())
  doctorProfileId String            @map("doctor_profile_id")
  organizationId  String            @map("organization_id")
  evidenceUrl     String            @map("evidence_url")
  status          CredentialStatus  @default(PENDING)
  reviewedByUserId String?          @map("reviewed_by_user_id")
  reviewedAt      DateTime?         @map("reviewed_at")
  justification   String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id])
  organization  Organization  @relation(fields: [organizationId], references: [id])
  reviewedBy    User?         @relation("CredentialReviewedBy", fields: [reviewedByUserId], references: [id])

  @@unique([doctorProfileId, organizationId])
  @@index([organizationId])
  @@map("credentials")
}

/// Plantão publicado por um hospital.
model Shift {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  specialty      String
  /// Valor do plantão em centavos (nunca float).
  valueCents     Int         @map("value_cents")
  /// Início/fim sempre em UTC; converter para exibição usando
  /// Organization.timezone.
  startsAt       DateTime    @map("starts_at")
  endsAt         DateTime    @map("ends_at")
  status         ShiftStatus @default(DRAFT)
  createdByUserId String     @map("created_by_user_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  createdBy    User          @relation("ShiftCreatedBy", fields: [createdByUserId], references: [id])
  applications Application[]

  @@index([organizationId, status])
  @@index([organizationId, specialty, valueCents])
  @@map("shifts")
}

/// Candidatura de um médico a um plantão. Constraint de unicidade
/// (shiftId, doctorProfileId) impede duplicidade em reenvio.
/// A garantia de "só uma aprovação por plantão" é reforçada por
/// índice único parcial (status = APPROVED) — ver migration.sql.
model Application {
  id              String            @id @default(uuid())
  shiftId         String            @map("shift_id")
  doctorProfileId String            @map("doctor_profile_id")
  organizationId  String            @map("organization_id")
  status          ApplicationStatus @default(PENDING)
  appliedAt       DateTime          @default(now()) @map("applied_at")
  decidedAt       DateTime?         @map("decided_at")
  decidedByUserId String?           @map("decided_by_user_id")
  justification   String?

  shift         Shift         @relation(fields: [shiftId], references: [id])
  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id])
  organization  Organization  @relation(fields: [organizationId], references: [id])
  decidedBy     User?         @relation("ApplicationDecidedBy", fields: [decidedByUserId], references: [id])

  @@unique([shiftId, doctorProfileId])
  @@index([organizationId])
  @@map("applications")
}

/// Notificação in-app/email. Payload não deve conter PII sensível
/// (ex.: evidência de CRM, texto de justificativa).
///
/// sourceOutboxEventId rastreia o OutboxEvent (T-5.1.1) que originou
/// esta notificação. A constraint única (sourceOutboxEventId, userId,
/// channel) torna a criação idempotente-segura: se o worker (T-5.1.2)
/// reprocessar o mesmo evento (retry após falha parcial de um outro
/// handler no mesmo job), tentar criar a mesma notificação de novo
/// vira no-op (violação de constraint tratada como sucesso), nunca
/// duplicata. channel entra na chave para que IN_APP (InAppService,
/// T-5.1.3) e EMAIL (EmailAdapter, T-5.1.4) do MESMO evento para o
/// MESMO destinatário não colidam entre si. NULL permanece distinto
/// entre linhas no Postgres, então isso não afeta notificações
/// futuras sem evento de origem.
model Notification {
  id                  String              @id @default(uuid())
  userId              String              @map("user_id")
  organizationId      String              @map("organization_id")
  channel             NotificationChannel
  type                String
  payload             Json
  sourceOutboxEventId String?             @map("source_outbox_event_id")
  readAt              DateTime?           @map("read_at")
  createdAt           DateTime            @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([sourceOutboxEventId, userId, channel])
  @@index([userId, readAt])
  @@index([organizationId])
  @@map("notifications")
}

/// Registro de entrega de email (T-5.1.4). A EXISTÊNCIA da linha
/// significa "provider confirmou entrega para este (evento,
/// destinatário)" — só é gravada DEPOIS de EmailProvider.send()
/// retornar sucesso, nunca antes. Isso é o que torna "retry não
/// reenvia email já confirmado como entregue" uma garantia real: um
/// envio que falhou não deixa linha nenhuma, então um retry
/// legitimamente tenta de novo; um envio confirmado bloqueia
/// reenvio via a constraint única.
model EmailDelivery {
  id                  String   @id @default(uuid())
  organizationId      String   @map("organization_id")
  userId              String   @map("user_id")
  sourceOutboxEventId String   @map("source_outbox_event_id")
  providerMessageId   String?  @map("provider_message_id")
  createdAt           DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([sourceOutboxEventId, userId])
  @@index([organizationId])
  @@map("email_deliveries")
}

/// Outbox transacional: eventos de domínio (plantão publicado,
/// candidatura decidida) gravados na MESMA transação da mudança de
/// negócio (ver OutboxService.enqueue). Se a transação de negócio
/// commita, o evento já está persistido — falha do processo logo
/// depois do commit nunca perde o evento pendente; ele continua lá
/// para o worker (T-5.1.2) processar. payload sempre inclui um
/// campo "version" — schema do evento é versionado, permitindo
/// evoluir o formato sem quebrar eventos antigos ainda não
/// processados.
model OutboxEvent {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  eventType      String            @map("event_type")
  payload        Json
  status         OutboxEventStatus @default(PENDING)
  attempts       Int               @default(0)
  availableAt    DateTime          @default(now()) @map("available_at")
  lastError      String?           @map("last_error")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([status, availableAt])
  @@map("outbox_events")
}

/// Trilha de auditoria imutável (sem update/delete a nível de
/// aplicação). organizationId nulo para ações globais de superadmin.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  actorUserId    String   @map("actor_user_id")
  action         String
  targetType     String   @map("target_type")
  targetId       String   @map("target_id")
  justification  String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  actor        User          @relation("AuditLogActor", fields: [actorUserId], references: [id])

  @@index([organizationId])
  @@index([targetType, targetId])
  @@map("audit_logs")
}
